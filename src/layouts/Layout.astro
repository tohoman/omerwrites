---
export interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  publishDate?: Date;
  updatedDate?: Date;
}
const {
  title,
  description = "Ömer's writing portfolio — essays, analysis, and academic work.",
  ogType = 'website',
  publishDate,
  updatedDate,
} = Astro.props;
import '../styles/global.css';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageTitle = `${title} · Ömer Writes`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,400;0,500;0,600;1,400;1,500&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="Ömer Writes" />
  {ogType === 'article' && publishDate && (
    <meta property="article:published_time" content={publishDate.toISOString()} />
  )}
  {ogType === 'article' && updatedDate && (
    <meta property="article:modified_time" content={updatedDate.toISOString()} />
  )}

  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
</head>
<body>
  <header class="site-header container">
    <a href="/" style="display:flex; align-items:center; gap:0.5rem; text-decoration:none;">
      <svg viewBox="0 0 40 40" width="24" height="24" xmlns="http://www.w3.org/2000/svg">
        <path d="M20 4 L30 16 L20 34 L10 16 Z" fill="none" stroke="#1C1F1D" stroke-width="1.6" stroke-linejoin="round"/>
        <line x1="20" y1="16" x2="20" y2="30" stroke="#1C1F1D" stroke-width="1.6"/>
        <circle cx="20" cy="16" r="1.4" fill="#1C1F1D"/>
        <path d="M17 36 Q20 39 23 36 Q20 34.5 17 36 Z" fill="#A8342A"/>
      </svg>
      <span style="font-family: var(--font-mono); font-weight:500; color: var(--color-ink); letter-spacing:0.02em;">omerwrites</span>
    </a>
    <nav style="display:flex; align-items:center; gap:1.5rem;">
      <a href="/essays">Essays</a>
      <span class="nav-categories">
        <a href="/essays#policy-analysis">Policy</a>
        <a href="/essays#personal-essays">Personal</a>
        <a href="/essays#academic">Academic</a>
        <a href="/essays#creative">Creative</a>
      </span>
      <a href="/about">About</a>
      <a href="/links">Links</a>
    </nav>
  </header>

  <main class="container" style="padding-bottom: 4rem;">
    <slot />
  </main>

  <footer class="container" style="padding: 2rem 1.5rem; border-top: 1px solid var(--color-rule); display:flex; gap:1.5rem;">
    <a href="https://x.com/" target="_blank">X</a>
    <a href="https://medium.com/" target="_blank">Medium</a>
    <a href="https://substack.com/" target="_blank">Substack</a>
  </footer>
</body>
</html>