---
import Layout from '../layouts/Layout.astro';
import EssayCard from '../components/EssayCard.astro';
import { getCollection } from 'astro:content';
import { JOURNEYS } from '../data/taxonomy';

const allEssays = await getCollection('essays', ({ data }) => !data.draft);
const sorted = [...allEssays].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = sorted.filter((e) => e.data.featured);
const featuredIds = new Set(featured.map((e) => e.id));
const secondary = sorted.filter((e) => !featuredIds.has(e.id)).slice(0, 6);

const journeyCount = (slug: string) => sorted.filter((e) => e.data.journey === slug).length;
const activeJourneys = JOURNEYS.filter((j) => journeyCount(j.slug) > 0);
---
<Layout title="Home">
  <section style="padding: 1.25rem 0 1.5rem;">
    <p class="eyebrow" style="margin-bottom: 0.4rem;">writing portfolio</p>
    <p style="font-family: var(--font-display); font-style: italic; font-size: 1.2rem; max-width: 48ch; margin: 0; color: var(--color-ink-soft);">
      I write about how geopolitics, economics, and faith fit together.
    </p>
  </section>

  <hr class="rule" />

  <section>
    <p class="eyebrow" style="margin-bottom: 1.2rem;">featured analysis</p>
    <div class="gallery">
      {featured.map((essay) => <EssayCard essay={essay} variant="featured" />)}
    </div>
    {featured.length === 0 && (
      <p style="color: var(--color-ink-soft); font-style: italic;">No featured essays yet.</p>
    )}
  </section>

  {activeJourneys.length > 0 && (
    <>
      <hr class="rule" />
      <section>
        <p class="eyebrow" style="margin-bottom: 1.2rem;">journeys — thematic arcs</p>
        <div class="journey-strip">
          {activeJourneys.map((j) => (
            <a href={`/journeys/${j.slug}`} class="journey-card">
              <h3>{j.title}</h3>
              <p>{j.dek}</p>
              <span class="journey-count">{journeyCount(j.slug)} essay{journeyCount(j.slug) === 1 ? '' : 's'} →</span>
            </a>
          ))}
        </div>
      </section>
    </>
  )}

  {secondary.length > 0 && (
    <>
      <hr class="rule" />
      <section>
        <p class="eyebrow" style="margin-bottom: 1.2rem;">recent essays</p>
        <div class="gallery gallery--secondary">
          {secondary.map((essay) => <EssayCard essay={essay} variant="secondary" />)}
        </div>
      </section>
    </>
  )}
</Layout>
